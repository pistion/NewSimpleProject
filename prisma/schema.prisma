  affectedService  String?   @map("affected_service")
  severity         String    @default("low") // low | medium | high
  count            Int       @default(1)
  avgDurationMs    Int?      @map("avg_duration_ms")
  peakDurationMs   Int?      @map("peak_duration_ms")
  firstSeenAt      DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at")
  status           String    @default("open") // open | dismissed | escalated
  dismissedByAdmin String?   @map("dismissed_by_admin")
  dismissedAt      DateTime? @map("dismissed_at")
  escalatedToEvent String?   @map("escalated_to_event")
  message          String?
  metadata         String    @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([warningType, status])
  @@index([severity, status])
  @@index([lastSeenAt])
  @@map("dashboard_warnings")
}

// ─── Retention Policy ─────────────────────────────────────────────────────────

model RetentionPolicy {
  id          String   @id @default(uuid())
  entityType  String   @unique @map("entity_type")
  retainDays  Int      @map("retain_days")
  description String?
  enabled     Boolean  @default(true)
  metadata    String   @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("retention_policies")
}

// ─── Service Requests (CRM intake — not support tickets) ─────────────────────
// The table has existed via ensureServiceRequestsTable() since before this
// model; serviceRequestService.js already queries prisma.serviceRequest, so
// this model makes that delegate real. Shape matches the ensured SQL exactly.

model ServiceRequest {
  id                     String    @id @default(uuid())
  requestNumber          String    @unique @map("request_number")
  userId                 String?   @map("user_id")
  organizationId         String?   @map("organization_id")
  source                 String    @default("public_form")
  requestType            String    @map("request_type")
  status                 String    @default("new")
  priority               String    @default("normal")
  contactName            String    @map("contact_name")
  contactEmail           String    @map("contact_email")
  contactPhone           String?   @map("contact_phone")
  companyName            String?   @map("company_name")
  subject                String
  description            String
  budgetRange            String?   @map("budget_range")
  timeline               String?
  preferredContactMethod String?   @map("preferred_contact_method")
  assignedAdminId        String?   @map("assigned_admin_id")
  convertedLeadId        String?   @map("converted_lead_id")
  convertedTicketId      String?   @map("converted_ticket_id")
  metadata               String    @default("{}")
  adminNotes             String?   @map("admin_notes")
  lastContactedAt        DateTime? @map("last_contacted_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([requestType, createdAt])
  @@index([userId, createdAt])
  @@index([assignedAdminId, status])
  @@index([contactEmail])
  @@map("service_requests")
}
