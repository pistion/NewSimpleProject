// Root-level Prisma schema for the Express server (deployed on Render).
// Provider: SQLite — database lives at /var/glondia/data/glondia.db on the persistent disk.
// JSON fields are stored as TEXT strings; routes handle JSON.stringify / JSON.parse.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Identity (auth) ──────────────────────────────────────────────────────────

model User {
  id                       String    @id @default(uuid())
  // Human-friendly customer reference (glondiac-XXXX), assigned at signup and
  // backfilled on first sign-in for older accounts.
  clientId                 String?   @unique @map("client_id")
  // IP address recorded when the account was created / client ID assigned.
  signupIp                 String?   @map("signup_ip")
  email                    String    @unique
  passwordHash             String    @map("password_hash")
  name                     String?
  role                     String    @default("owner")
  planId                   String    @default("free") @map("plan_id")
  // Profile + identity (managed by the customer and admins).
  phone                    String?
  profileDetails           String    @default("{}") @map("profile_details") // JSON as TEXT
  // idPhotoPath = private ID verification document (admin/owner only).
  // avatarPath  = profile headshot/avatar shown in the UI.
  idPhotoPath              String?   @map("id_photo_path")
  avatarPath               String?   @map("avatar_path")
  // Account lifecycle: active | suspended | disabled | deleted. Users are never
  // hard-deleted — payment/deployment history must survive a soft delete.
  accountStatus            String    @default("active") @map("account_status")
  disabledAt               DateTime? @map("disabled_at")
  disabledReason           String?   @map("disabled_reason")
  deletedAt                DateTime? @map("deleted_at")
  reactivatedAt            DateTime? @map("reactivated_at")
  // Launch promo lifecycle. Eligibility is granted to the first N registered
  // users (DEPLOYMENT_PROMO_SIGNUP_LIMIT, default 20). The K50 promo can be
  // claimed once per user; promoClaimedAt is set only after a verified payment.
  promoEligible            Boolean   @default(false) @map("promo_eligible")
  promoSignupRank          Int?      @map("promo_signup_rank")
  promoClaimedAt           DateTime? @map("promo_claimed_at")
  promoClaimedOrderId      String?   @map("promo_claimed_order_id")
  promoClaimedDeploymentId String?   @map("promo_claimed_deployment_id")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  projects      ClientProject[]
  builderProjects BuilderProject[]

  @@index([accountStatus])
  @@index([createdAt])
  @@index([promoSignupRank])
  @@map("users")
}

// ─── Canonical Site Builder lifecycle ────────────────────────────────────────

model BuilderProject {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  clientProjectId      String?   @map("client_project_id")
  sourceType           String    @map("source_type") // template | github | zip
  templateId           String?   @map("template_id")
  templateVersion      String?   @map("template_version")
  templateSourceCommit String?   @map("template_source_commit")
  templateManifestHash String?   @map("template_manifest_hash")
  name                 String
  slug                 String
  status               String    @default("DRAFT")
  version              Int       @default(1)
  currentRevisionId    String?   @map("current_revision_id")
  approvedRevisionId   String?   @map("approved_revision_id")
  planJson             String    @default("{}") @map("plan_json")
  answerSheetJson      String    @default("{}") @map("answer_sheet_json")
  metadata             String    @default("{}")
  archivedAt           DateTime? @map("archived_at")
  deletedAt            DateTime? @map("deleted_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user            User                    @relation(fields: [userId], references: [id], onDelete: Restrict)
  revisions       BuilderRevision[]
  jobs            BuilderJob[]
  previewGrants   BuilderPreviewGrant[]
  deploymentLinks BuilderDeploymentLink[]

  @@unique([userId, slug])
  @@index([userId, status])
  @@index([clientProjectId])
  @@index([templateId, templateVersion])
  @@index([updatedAt])
  @@map("builder_projects")
}

model BuilderRevision {
  id                  String    @id @default(uuid())
  projectId           String    @map("project_id")
  revisionNumber      Int       @map("revision_number")
  parentRevisionId    String?   @map("parent_revision_id")
  status              String    @default("DRAFT")
  planSnapshotJson    String    @default("{}") @map("plan_snapshot_json")
  answerSheetJson     String    @default("{}") @map("answer_sheet_json")
  generatedSiteJson   String    @default("{}") @map("generated_site_json")
  artifactLocation    String?   @map("artifact_location")
  artifactChecksum    String?   @map("artifact_checksum")
  sourceCommit        String?   @map("source_commit")
  generationModel     String?   @map("generation_model")
  generationUsageJson String    @default("{}") @map("generation_usage_json")
  validationJson      String    @default("{}") @map("validation_json")
  changeRequestJson   String    @default("{}") @map("change_request_json")
  createdByUserId     String?   @map("created_by_user_id")
  approvedByUserId    String?   @map("approved_by_user_id")
  approvedAt          DateTime? @map("approved_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  project         BuilderProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  jobs            BuilderJob[]
  previewGrants   BuilderPreviewGrant[]
  deploymentLinks BuilderDeploymentLink[]

  @@unique([projectId, revisionNumber])
  @@index([projectId, status])
  @@index([artifactChecksum])
  @@map("builder_revisions")
}

model BuilderJob {
  id             String    @id @default(uuid())
  projectId      String    @map("project_id")
  revisionId     String?   @map("revision_id")
  jobType        String    @map("job_type")
  status         String    @default("QUEUED")
  stage          String?
  idempotencyKey String    @unique @map("idempotency_key")
  requestHash    String?   @map("request_hash")
  payloadJson    String    @default("{}") @map("payload_json")
  resultJson     String    @default("{}") @map("result_json")
  progressJson   String    @default("{}") @map("progress_json")
  errorCode      String?   @map("error_code")
  errorMessage   String?   @map("error_message")
  attempt        Int       @default(0)
  maxAttempts    Int       @default(3) @map("max_attempts")
  availableAt    DateTime  @default(now()) @map("available_at")
  leaseOwner     String?   @map("lease_owner")
  leaseExpiresAt DateTime? @map("lease_expires_at")
  startedAt      DateTime? @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  cancelledAt    DateTime? @map("cancelled_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  project  BuilderProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revision BuilderRevision? @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  events   BuilderJobEvent[]

  @@index([status, availableAt])
  @@index([leaseExpiresAt])
  @@index([projectId, createdAt])
  @@index([revisionId])
  @@map("builder_jobs")
}

model BuilderJobEvent {
  id          String   @id @default(uuid())
  jobId       String   @map("job_id")
  sequence    Int
  stage       String?
  level       String   @default("info")
  message     String
  detailsJson String   @default("{}") @map("details_json")
  createdAt   DateTime @default(now()) @map("created_at")

  job BuilderJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, sequence])
  @@index([jobId, createdAt])
  @@map("builder_job_events")
}

model BuilderPreviewGrant {
  id              String    @id @default(uuid())
  projectId       String    @map("project_id")
  revisionId      String    @map("revision_id")
  tokenHash       String    @unique @map("token_hash")
  audience        String    @default("owner")
  expiresAt       DateTime  @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  lastUsedAt      DateTime? @map("last_used_at")
  createdByUserId String?   @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  project  BuilderProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revision BuilderRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@index([projectId, expiresAt])
  @@index([revisionId])
  @@map("builder_preview_grants")
}

model BuilderDeploymentLink {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  revisionId     String   @map("revision_id")
  deploymentId   String   @unique @map("deployment_id")
  idempotencyKey String   @unique @map("idempotency_key")
  status         String   @default("QUEUED")
  isCurrent      Boolean  @default(true) @map("is_current")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project  BuilderProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revision BuilderRevision @relation(fields: [revisionId], references: [id], onDelete: Restrict)

  @@index([projectId, isCurrent])
  @@index([revisionId])
  @@index([status])
  @@map("builder_deployment_links")
}

model AiUsageEvent {
  id                  String   @id @default(uuid())
  userId              String?  @map("user_id")
  projectId           String?  @map("project_id")
  jobId               String?  @map("job_id")
  provider            String
  model               String
  operation           String
  promptTokens        Int      @default(0) @map("prompt_tokens")
  completionTokens    Int      @default(0) @map("completion_tokens")
  estimatedCostMicros Int      @default(0) @map("estimated_cost_micros")
  status              String
  requestId           String?  @map("request_id")
  metadata            String   @default("{}")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([jobId])
  @@map("ai_usage_events")
}

// ─── Client Projects ─────────────────────────────────────────────────────────

model ClientProject {
  id          String    @id @default(uuid())
  projectCode String    @unique @map("project_code")
  userId      String?   @map("user_id")
  clientId    String?   @map("client_id")
  workspaceId String?   @map("workspace_id")
  name        String
  slug        String
  serviceType String    @default("website") @map("service_type") // website | hosting | domain | email | vps | consultation | build | support | other
  status      String    @default("draft") // draft | active | paused | completed | archived
  priority    String    @default("normal")
  description String?
  metadata    String    @default("{}")
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([userId, slug])
  @@index([userId, serviceType])
  @@index([clientId])
  @@index([workspaceId])
  @@index([status, createdAt])
  @@map("client_projects")
}

// User-facing notifications (distinct from internal AuditLog history).
model Notification {
  id         String    @id @default(uuid())
  userId     String?   @map("user_id")
  audience   String    @default("user") // user | admin | all
  type       String    @default("info") // info | success | warning | danger | billing | deployment | account | receipt | subscription
  title      String
  message    String
  actionUrl  String?   @map("action_url")
  entityType String?   @map("entity_type")
  entityId   String?   @map("entity_id")
  metadata   String    @default("{}") // JSON as TEXT
  readAt     DateTime? @map("read_at")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([userId, readAt])
  @@index([audience, createdAt])
  @@index([type, createdAt])
  @@index([entityType, entityId])
  @@map("notifications")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── VPS Hosting (Vultr) ──────────────────────────────────────────────────────

model VpsService {
  id                 String    @id @default(uuid())
  organizationId     String    @map("organization_id")
  createdByUserId    String?   @map("created_by_user_id")
  checkoutOrderId    String?   @map("checkout_order_id")
  provider           String    @default("vultr")
  providerInstanceId String    @map("provider_instance_id")
  label              String
  hostname           String
  region             String
  plan               String
  osId               Int       @map("os_id")
  osName             String?   @map("os_name")
  status             String    @default("pending")
  mainIp             String?   @map("main_ip")
  vcpuCount          Int?      @map("vcpu_count")
  ramMb              Int?      @map("ram_mb")
  diskGb             Int?      @map("disk_gb")
  monthlyCostCents   Int       @map("monthly_cost_cents")
  markupPercent      Float     @default(30) @map("markup_percent")
  markupAmountCents  Int       @map("markup_amount_cents")
  totalPriceCents    Int       @map("total_price_cents")
  currency           String    @default("USD")
  paypalOrderId      String?   @map("paypal_order_id")
  paypalCaptureId    String?   @map("paypal_capture_id")
  paymentStatus      String    @default("pending") @map("payment_status")
  metadata           String    @default("{}") // JSON as TEXT
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  actionLogs VpsActionLog[]

  @@index([organizationId])
  @@index([providerInstanceId])
  @@index([paypalOrderId])
  @@index([checkoutOrderId])
  @@map("vps_services")
}

model VpsActionLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  vpsServiceId   String   @map("vps_service_id")
  actorUserId    String?  @map("actor_user_id")
  action         String
  status         String   @default("pending")
  request        String   @default("{}") // JSON as TEXT
  response       String   @default("{}") // JSON as TEXT
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")

  vpsService VpsService @relation(fields: [vpsServiceId], references: [id], onDelete: Cascade)

  @@index([vpsServiceId])
  @@index([organizationId, createdAt])
  @@map("vps_action_logs")
}

// Ownership map for provider-account-level resources (SSH keys, snapshots,
// backups…). The Vultr account is shared across all customers, so every
// resource a customer creates is recorded here and list/delete/restore are
// scoped to the owning organization.
model ProviderResource {
  id                 String    @id @default(uuid())
  organizationId     String    @map("organization_id")
  userId             String?   @map("user_id")
  serviceId          String?   @map("service_id")
  provider           String    @default("vultr")
  resourceType       String    @map("resource_type") // instance | ssh_key | snapshot | backup
  providerResourceId String    @map("provider_resource_id")
  name               String?
  status             String    @default("active")
  metadata           String    @default("{}") // JSON as TEXT
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@unique([provider, resourceType, providerResourceId])
  @@index([organizationId, resourceType])
  @@index([serviceId])
  @@map("provider_resources")
}

// ─── Web Hosting (Render-powered) ────────────────────────────────────────────

model WebHostingService {
  id                String    @id @default(uuid())
  organizationId    String    @map("organization_id")
  createdByUserId   String?   @map("created_by_user_id")
  checkoutOrderId   String?   @map("checkout_order_id")
  provider          String    @default("render")
  providerServiceId String?   @map("provider_service_id")
  name              String
  slug              String
  serviceType       String    @default("web_service") @map("service_type")
  status            String    @default("pending")
  region            String?
  plan              String?
  url               String?
  customDomain      String?   @map("custom_domain")
  monthlyCostCents  Int       @default(0) @map("monthly_cost_cents")
  markupPercent     Float     @default(30) @map("markup_percent")
  markupAmountCents Int       @default(0) @map("markup_amount_cents")
  totalPriceCents   Int       @default(0) @map("total_price_cents")
  currency          String    @default("USD")
  billingModel      String    @default("monthly") @map("billing_model")
  paymentStatus     String    @default("pending") @map("payment_status")
  // Deploy-first billing: grace deadline + payment timestamp + why removed.
  billingDueAt      DateTime? @map("billing_due_at")
  paidAt            DateTime? @map("paid_at")
  deletedReason     String?   @map("deleted_reason")
  metadata          String    @default("{}") // JSON as TEXT
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([providerServiceId])
  @@index([checkoutOrderId])
  @@map("web_hosting_services")
}

// ─── Business Services (domains, email hosting, SSL, etc.) ───────────────────

model BusinessService {
  id                 String    @id @default(uuid())
  organizationId     String    @map("organization_id")
  createdByUserId    String?   @map("created_by_user_id")
  checkoutOrderId    String?   @map("checkout_order_id")
  type               String // domain | email | ssl | etc.
  provider           String // spaceship | render | etc.
  providerServiceId  String?   @map("provider_service_id")
  name               String
  status             String    @default("active")
  billingCycle       String    @default("annual") @map("billing_cycle")
  billingAmountCents Int       @default(0) @map("billing_amount_cents")
  markupPercent      Float     @default(30) @map("markup_percent")
  markupAmountCents  Int       @default(0) @map("markup_amount_cents")
  totalPriceCents    Int       @default(0) @map("total_price_cents")
  currency           String    @default("USD")
  paymentStatus      String    @default("pending") @map("payment_status")
  renewsAt           DateTime? @map("renews_at")
  expiresAt          DateTime? @map("expires_at")
  autoRenew          Boolean   @default(true) @map("auto_renew")
  metadata           String    @default("{}") // JSON as TEXT
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([type, status])
  @@index([checkoutOrderId])
  @@map("business_services")
}

// ─── Checkout Orders ──────────────────────────────────────────────────────────

model CheckoutOrder {
  id                String    @id @default(uuid())
  organizationId    String    @map("organization_id")
  userId            String?   @map("user_id")
  type              String
  provider          String    @default("paypal")
  providerOrderId   String?   @unique @map("provider_order_id")
  providerCaptureId String?   @map("provider_capture_id")
  status            String    @default("pending")
  currency          String    @default("USD")
  actualAmountCents Int       @default(0) @map("actual_amount_cents")
  markupPercent     Float     @default(30) @map("markup_percent")
  markupAmountCents Int       @default(0) @map("markup_amount_cents")
  totalAmountCents  Int       @default(0) @map("total_amount_cents")
  // Deploy-first billing link: which deployment this order pays for.
  deploymentId      String?   @map("deployment_id")
  dueAt             DateTime? @map("due_at")
  paidAt            DateTime? @map("paid_at")
  metadata          String    @default("{}") // JSON as TEXT
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  receipts PaymentReceipt[]

  @@index([organizationId, status])
  @@index([type, createdAt])
  @@index([userId, status])
  @@index([deploymentId])
  @@map("checkout_orders")
}

// ─── Payment Receipts (manual bank transfer proof) ───────────────────────────
// Uploaded to the Render persistent disk (DATA_DIR/receipts/...). Admin reviews
// and approves/rejects. Approval marks the linked order + deployment paid.

model DeploymentSubscription {
  id                 String    @id @default(uuid())
  deploymentId       String    @unique @map("deployment_id")
  userId             String?   @map("user_id")
  checkoutOrderId    String?   @map("checkout_order_id")
  status             String    @default("trialing")
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  nextBillingAt      DateTime? @map("next_billing_at")
  renewalReminderAt  DateTime? @map("renewal_reminder_at")
  lastPaidAt         DateTime? @map("last_paid_at")
  renewalCount       Int       @default(0) @map("renewal_count")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([nextBillingAt])
  @@index([renewalReminderAt])
  @@map("deployment_subscriptions")
}

model PaymentReceipt {
  id               String    @id @default(uuid())
  checkoutOrderId  String    @map("checkout_order_id")
  userId           String?   @map("user_id")
  deploymentId     String?   @map("deployment_id")
  method           String    @default("bank_transfer")
  fileName         String    @map("file_name")
  filePath         String    @map("file_path")
  fileType         String?   @map("file_type")
  fileSize         Int       @default(0) @map("file_size")
  amountCents      Int       @default(0) @map("amount_cents")
  currency         String    @default("PGK")
  status           String    @default("pending") // pending | approved | rejected
  note             String?
  reviewedByUserId String?   @map("reviewed_by_user_id")
  reviewedAt       DateTime? @map("reviewed_at")
  reviewNote       String?   @map("review_note")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  checkoutOrder CheckoutOrder @relation(fields: [checkoutOrderId], references: [id], onDelete: Cascade)

  @@index([checkoutOrderId])
  @@index([userId])
  @@index([status, createdAt])
  @@map("payment_receipts")
}

// ─── Deployment Cleanup Jobs (audit trail for unpaid-grace enforcement) ──────
// One row per cleanup action taken by the 12-hour grace enforcement service.
// DB history is preserved — records are never deleted.

model DeploymentCleanupJob {
  id              String   @id @default(uuid())
  deploymentId    String   @map("deployment_id")
  checkoutOrderId String?  @map("checkout_order_id")
  userId          String?  @map("user_id")
  action          String // suspend | delete | skip
  reason          String?
  renderServiceId String?  @map("render_service_id")
  status          String   @default("done") // done | failed
  detail          String   @default("{}") // JSON as TEXT
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([deploymentId])
  @@index([createdAt])
  @@map("deployment_cleanup_jobs")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  actorUserId    String?  @map("actor_user_id")
  action         String
  entityType     String?  @map("entity_type")
  entityId       String?  @map("entity_id")
  status         String   @default("success")
  method         String?
  path           String?
  metadata       String   @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ─── Service Access (central monthly access pass) ────────────────────────────
// One row per user-owned service instance. accessStatus + billingStatus +
// adminStatus together decide whether the user can use the service right now.

model ServiceAccess {
  id              String    @id @default(uuid())
  userId          String?   @map("user_id")
  organizationId  String?   @map("organization_id")
  serviceType     String    @map("service_type") // hosting | domain | vps | email | builder | support | other
  serviceId       String    @map("service_id")
  serviceName     String?   @map("service_name")
  accessStatus    String    @default("pending") @map("access_status") // pending | active | suspended | expired | cancelled | deleted
  billingStatus   String    @default("pending") @map("billing_status") // trial | pending | paid | overdue | failed | cancelled | free
  adminStatus     String    @default("allowed") @map("admin_status") // allowed | blocked | review_required
  planId          String?   @map("plan_id")
  checkoutOrderId String?   @map("checkout_order_id")
  subscriptionId  String?   @map("subscription_id")
  startsAt        DateTime? @map("starts_at")
  expiresAt       DateTime? @map("expires_at")
  lastCheckedAt   DateTime? @map("last_checked_at")
  lastActivityAt  DateTime? @map("last_activity_at")
  suspendedAt     DateTime? @map("suspended_at")
  suspendedReason String?   @map("suspended_reason")
  metadata        String    @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([serviceType, serviceId])
  @@index([userId, serviceType])
  @@index([organizationId, serviceType])
  @@index([accessStatus])
  @@index([billingStatus])
  @@index([adminStatus])
  @@index([expiresAt])
  @@map("service_access")
}

// ─── Admin Policy (instruction / config data) ────────────────────────────────

