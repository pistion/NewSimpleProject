# ─── Copy this file to .env and fill in real values ─────────────────────────
# For Render.com production, set these in the service's Environment dashboard.

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=glondia-backend
# Render listens on port 10000 by default (set APP_PORT=10000 on Render)
APP_PORT=4000

# ── URLs ─────────────────────────────────────────────────────────────────────
# Local dev:
APP_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000/api/v1
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=

# Production (Render.com) — replace with your actual service URLs:
# APP_URL=https://glondia-backend.onrender.com
# API_BASE_URL=https://glondia-backend.onrender.com/api/v1
# FRONTEND_URL=https://glondiasites.onrender.com
# CORS_ORIGINS=https://glondiasites.onrender.com

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://glondia:glondia_password@localhost:5432/glondia
# Production: use the Internal Connection URL from Render PostgreSQL dashboard

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production: use the Internal URL from Render Redis dashboard

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
# Generate secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_min_16_chars
# ⚠️  LOCAL TESTING ONLY — bypasses JWT on every guarded route. NEVER set true in production.
AUTH_DISABLED=false
JWT_REFRESH_SECRET=change_me_refresh_secret_min_16_chars
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# ─── Field encryption ─────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=change_me_32_bytes_as_base64

# ─── Object storage ───────────────────────────────────────────────────────────
# Local dev uses MinIO (docker-compose)
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=glondia_minio
S3_SECRET_ACCESS_KEY=glondia_minio_secret
S3_ASSETS_BUCKET=glondia-assets
S3_ARTIFACTS_BUCKET=glondia-artifacts
S3_PUBLIC_URL=http://localhost:9000

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=log
EMAIL_FROM=no-reply@glondia.app
RESEND_API_KEY=

# ─── Stripe billing ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_SANDBOX=true
PLATFORM_MARKUP_PERCENT=30
PLATFORM_PAYPAL_EMAIL=
DOMAIN_REGISTRAR_COST_ACCOUNT=
HOSTING_COST_ACCOUNT=

# ─── Render hosting provider ──────────────────────────────────────────────────
RENDER_API_KEY=your_render_api_key_here
RENDER_OWNER_ID=your_render_owner_or_workspace_id_here
RENDER_API_BASE_URL=https://api.render.com/v1

# ─── Vultr VPS hosting ────────────────────────────────────────────────────────
# Get your API key from https://my.vultr.com/settings/#settingsapi
VULTR_API_KEY=
VULTR_API_BASE_URL=https://api.vultr.com/v2

# ─── Spaceship registrar ──────────────────────────────────────────────────────
SPACESHIP_API_KEY=your_spaceship_api_key_here
SPACESHIP_API_SECRET=your_spaceship_api_secret_here
SPACESHIP_DEFAULT_CONTACT_ID=

# ─── OpenAI (AI template editing) ────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
