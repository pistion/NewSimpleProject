generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  name            String?
  avatarUrl       String?    @map("avatar_url")
  passwordHash    String?    @map("password_hash")
  emailVerifiedAt DateTime?  @map("email_verified_at")
  status          String     @default("pending")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  apiKeys                    ApiKey[]                     @relation("ApiKeyUser")
  assetsUploaded             Asset[]                      @relation("AssetUploader")
  auditLogs                  AuditLog[]                   @relation("AuditActor")
  builderPageVersionsCreated BuilderPageVersion[]         @relation("BuilderPageVersionCreator")
  builderSitesCreated        BuilderSite[]                @relation("BuilderSiteCreator")
  createdOrganizations       Organization[]               @relation("OrganizationCreator")
  invitedMemberships         OrganizationMember[]         @relation("InvitedMemberships")
  memberships                OrganizationMember[]         @relation("UserMemberships")
  notificationPreferences    NotificationPreference[]
  notifications              Notification[]
  oauthAccounts              OauthAccount[]
  projectsCreated            Project[]                    @relation("ProjectCreator")
  deploymentsTriggered       Deployment[]                 @relation("DeploymentTrigger")
  domainsCreated             Domain[]                     @relation("DomainCreator")
  sessions                   Session[]
  userActivityLogs           ActivityLog[]                @relation("ActivityActor")
  ProjectEnvironmentVariable ProjectEnvironmentVariable[]
  vpsServicesCreated         VpsService[]                 @relation("VpsServiceCreator")
  webHostingServicesCreated  WebHostingService[]          @relation("WebHostingServiceCreator")
  businessServicesCreated    BusinessService[]            @relation("BusinessServiceCreator")

  @@map("users")
}

model Session {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash")
  deviceLabel      String?   @map("device_label")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId])
  @@map("sessions")
}

model OauthAccount {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  provider              String
  providerUserId        String   @map("provider_user_id")
  accessTokenEncrypted  String?  @map("access_token_encrypted")
  refreshTokenEncrypted String?  @map("refresh_token_encrypted")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model ApiKey {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  userId         String    @map("user_id")
  name           String
  keyHash        String    @map("key_hash")
  prefix         String
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  scopes         Json      @default("[]")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("ApiKeyUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([prefix])
  @@index([userId])
  @@map("api_keys")
}

model Organization {
  id               String             @id @default(uuid())
  name             String
  slug             String             @unique
  billingEmail     String?            @map("billing_email")
  stripeCustomerId String?            @unique @map("stripe_customer_id")
  status           String             @default("active")
  createdByUserId  String?            @map("created_by_user_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  activityLogs               ActivityLog[]
  invitesSent                OrganizationInvite[]         @relation("OrganizationInvites")
  apiKeys                    ApiKey[]
  artifacts                  Artifact[]
  assets                     Asset[]
  auditLogs                  AuditLog[]
  billingInvoices            BillingInvoice[]
  billingUsageRecords        BillingUsageRecord[]
  builderPageVersions        BuilderPageVersion[]
  builderPages               BuilderPage[]
  builderSites               BuilderSite[]
  createdBy                  User?                        @relation("OrganizationCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  deploymentAliases          DeploymentAlias[]
  deployments                Deployment[]
  deploymentLogs             DeploymentLog[]
  domains                    Domain[]
  dnsRecords                 DnsRecord[]
  members                    OrganizationMember[]
  notificationPreferences    NotificationPreference[]
  notifications              Notification[]
  outgoingWebhookDeliveries  OutgoingWebhookDelivery[]
  outgoingWebhookEndpoints   OutgoingWebhookEndpoint[]
  projects                   Project[]
  roles                      Role[]
  vpsServices                VpsService[]
  vpsActionLogs              VpsActionLog[]
  webHostingServices         WebHostingService[]
  businessServices           BusinessService[]
  sslCertificates            SslCertificate[]
  subscriptions              BillingSubscription[]
  webhookEvents              WebhookEvent[]
  ProjectEnvironmentVariable ProjectEnvironmentVariable[]

  @@index([createdByUserId])
  @@index([status])
  @@map("organizations")
}

model OrganizationMember {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  userId          String    @map("user_id")
  roleId          String    @map("role_id")
  status          String    @default("invited")
  invitedByUserId String?   @map("invited_by_user_id")
  joinedAt        DateTime? @map("joined_at")
  removedAt       DateTime? @map("removed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  invitedBy    User?        @relation("InvitedMemberships", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  user         User         @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([invitedByUserId])
  @@index([roleId])
  @@index([status])
  @@index([userId])
  @@map("organization_members")
}

model OrganizationInvite {
  id               String    @id @default(uuid())
  organizationId   String    @map("organization_id")
  invitedByUserId  String    @map("invited_by_user_id")
  acceptedByUserId String?   @map("accepted_by_user_id")
  email            String
  roleKey          String    @map("role_key")
  token            String    @unique
  expiresAt        DateTime  @map("expires_at")
  acceptedAt       DateTime? @map("accepted_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  organization Organization @relation("OrganizationInvites", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email, organizationId])
  @@index([organizationId])
  @@index([token])
  @@map("organization_invites")
}

model Role {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  name           String
  key            String
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")

  members         OrganizationMember[]
  organization    Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([organizationId, key])
  @@index([isSystem])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  name        String
  description String?
  module      String

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Project {
  id                 String        @id @default(uuid())
  organizationId     String        @map("organization_id")
  name               String
  slug               String
  framework          String?
  repositoryProvider String?       @map("repository_provider")
  repositoryOwner    String?       @map("repository_owner")
  repositoryName     String?       @map("repository_name")
  repositoryId       String?       @map("repository_id")
  renderServiceId    String?       @map("render_service_id")
  productionBranch   String?       @default("main") @map("production_branch")
  rootDirectory      String?       @map("root_directory")
  buildCommand       String?       @map("build_command")
  outputDirectory    String?       @map("output_directory")
  installCommand     String?       @map("install_command")
  status             String        @default("active")
  createdByUserId    String?       @map("created_by_user_id")
  deletedAt          DateTime?     @map("deleted_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  createdBy          User?                        @relation("ProjectCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  aliases            DeploymentAlias[]
  artifacts          Artifact[]
  deployments        Deployment[]
  domains            Domain[]
  envVars            ProjectEnvironmentVariable[]
  organization       Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vpsServices        VpsService[]
  webHostingServices WebHostingService[]          @relation("WebHostingProject")

  @@unique([organizationId, slug])
  @@index([createdByUserId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("projects")
}

model ProjectEnvironmentVariable {
  id              String   @id @default(uuid())
  projectId       String   @map("project_id")
  organizationId  String   @map("organization_id")
  key             String
  valueEncrypted  String   @map("value_encrypted")
  environment     String
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdBy    User?        @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key, environment])
  @@index([createdByUserId])
  @@index([organizationId, environment])
  @@index([projectId])
  @@map("project_environment_variables")
}

model Domain {
  id                String       @id @default(uuid())
  organizationId    String       @map("organization_id")
  projectId         String?      @map("project_id")
  hostname          String
  rootDomain        String       @map("root_domain")
  status            String       @default("pending_verification")
  verificationToken String       @map("verification_token")
  verifiedAt        DateTime?    @map("verified_at")
  createdByUserId   String?      @map("created_by_user_id")
  deletedAt         DateTime?    @map("deleted_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  aliases          DeploymentAlias[]
  createdBy        User?            @relation("DomainCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  dnsRecords       DnsRecord[]
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sslCertificates  SslCertificate[]

  @@unique([organizationId, hostname])
  @@index([createdByUserId])
  @@index([organizationId, status])
  @@index([projectId])
  @@map("domains")
}

model DnsRecord {
  id               String   @id @default(uuid())
  organizationId   String   @map("organization_id")
  domainId         String   @map("domain_id")
  type             String
  name             String
  value            String
  ttl              Int      @default(3600)
  priority         Int?
  proxied          Boolean  @default(false)
  providerRecordId String?  @map("provider_record_id")
  status           String   @default("pending")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  domain       Domain       @relation(fields: [domainId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@index([organizationId])
  @@index([status])
  @@map("dns_records")
}

model SslCertificate {
  id             String    @id @default(uuid())
  domainId       String    @map("domain_id")
  organizationId String    @map("organization_id")
  status         String    @default("pending")
  provider       String
  certificateRef String?   @map("certificate_ref")
  issuedAt       DateTime? @map("issued_at")
  expiresAt      DateTime? @map("expires_at")
  lastCheckedAt  DateTime? @map("last_checked_at")
  errorMessage   String?   @map("error_message")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  domain       Domain       @relation(fields: [domainId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([domainId, status])
  @@index([expiresAt])
  @@index([organizationId])
  @@map("ssl_certificates")
}

model BuilderSite {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  projectId       String?   @map("project_id")
  name            String
  slug            String
  templateId      String?   @map("template_id")
  status          String    @default("draft")
  publishedAt     DateTime? @map("published_at")
  createdByUserId String?   @map("created_by_user_id")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  createdBy    User?         @relation("BuilderSiteCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pages        BuilderPage[]
  template     Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([organizationId, slug])
  @@index([createdByUserId])
  @@index([organizationId, status])
  @@map("builder_sites")
}

model BuilderPage {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  siteId         String    @map("site_id")
  path           String
  title          String
  content        Json      @default("{}")
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @map("seo_description")
  status         String    @default("draft")
  sortOrder      Int       @default(0) @map("sort_order")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site         BuilderSite          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  versions     BuilderPageVersion[]

  @@unique([siteId, path])
  @@index([organizationId])
  @@index([siteId, status])
  @@map("builder_pages")
}

model BuilderPageVersion {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  siteId          String    @map("site_id")
  pageId          String    @map("page_id")
  versionNumber   Int       @map("version_number")
  contentJson     Json      @map("content_json")
  label           String?
  createdByUserId String?   @map("created_by_user_id")
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  createdBy    User?        @relation("BuilderPageVersionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  page         BuilderPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, versionNumber])
  @@index([organizationId])
  @@index([pageId, publishedAt])
  @@map("builder_page_versions")
}

model Template {
  id              String   @id @default(uuid())
  name            String
  category        String
  previewImageUrl String?  @map("preview_image_url")
  contentJson     Json     @map("content_json")
  isPublic        Boolean  @default(true) @map("is_public")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  sites BuilderSite[]

  @@index([category])
  @@index([isPublic])
  @@index([isActive, sortOrder])
  @@map("templates")
}

model BillingPlan {
  id                String   @id @default(uuid())
  key               String   @unique
  name              String
  description       String?
  priceMonthlyCents Int      @default(0) @map("price_monthly_cents")
  priceYearlyCents  Int      @default(0) @map("price_yearly_cents")
  currency          String   @default("USD")
  limits            Json     @default("{}")
  features          Json     @default("{}")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  subscriptions BillingSubscription[]

  @@index([isActive])
  @@map("billing_plans")
}

model BillingSubscription {
  id                     String   @id @default(uuid())
  organizationId         String   @map("organization_id")
  planId                 String   @map("plan_id")
  provider               String   @default("stripe")
  status                 String   @default("active")
  currentPeriodStart     DateTime @map("current_period_start")
  currentPeriodEnd       DateTime @map("current_period_end")
  cancelAtPeriodEnd      Boolean  @default(false) @map("cancel_at_period_end")
  providerCustomerId     String?  @map("provider_customer_id")
  providerSubscriptionId String?  @unique @map("provider_subscription_id")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  invoices     BillingInvoice[]
  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         BillingPlan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  usageRecords BillingUsageRecord[]

  @@index([organizationId, status])
  @@index([planId])
  @@map("billing_subscriptions")
}

model BillingInvoice {
  id                String    @id @default(uuid())
  organizationId    String    @map("organization_id")
  subscriptionId    String?   @map("subscription_id")
  providerInvoiceId String?   @unique @map("provider_invoice_id")
  status            String    @default("open")
  currency          String    @default("USD")
  amountDueCents    Int       @default(0) @map("amount_due_cents")
  amountPaidCents   Int       @default(0) @map("amount_paid_cents")
  description       String?
  periodStart       DateTime? @map("period_start")
  periodEnd         DateTime? @map("period_end")
  issuedAt          DateTime? @map("issued_at")
  paidAt            DateTime? @map("paid_at")
  hostedInvoiceUrl  String?   @map("hosted_invoice_url")
  createdAt         DateTime  @default(now()) @map("created_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([subscriptionId])
  @@map("billing_invoices")
}

model BillingUsageRecord {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  projectId      String?  @map("project_id")
  subscriptionId String?  @map("subscription_id")
  vpsServiceId   String?  @map("vps_service_id")
  webHostingId   String?  @map("web_hosting_id")
  metricKey      String   @map("metric_key")
  quantity       Int      @default(0)
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  vpsService   VpsService?          @relation("VpsUsageRecords", fields: [vpsServiceId], references: [id], onDelete: SetNull)
  webHosting   WebHostingService?   @relation("WebHostingUsageRecords", fields: [webHostingId], references: [id], onDelete: SetNull)

  @@index([organizationId, metricKey, periodStart])
  @@index([projectId])
  @@index([subscriptionId])
  @@index([vpsServiceId])
  @@index([webHostingId])
  @@map("billing_usage_records")
}

model CheckoutOrder {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  userId            String?  @map("user_id")
  type              String
  provider          String   @default("paypal")
  providerOrderId   String?  @unique @map("provider_order_id")
  providerCaptureId String?  @map("provider_capture_id")
  status            String   @default("pending")
  currency          String   @default("USD")
  actualAmountCents Int      @default(0) @map("actual_amount_cents")
  markupPercent     Decimal  @default(30) @map("markup_percent")
  markupAmountCents Int      @default(0) @map("markup_amount_cents")
  totalAmountCents  Int      @default(0) @map("total_amount_cents")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  payments           Payment[]
  vpsServices        VpsService[]        @relation("VpsCheckoutOrder")
  webHostingServices WebHostingService[] @relation("WebHostingCheckoutOrder")
  businessServices   BusinessService[]   @relation("BusinessServiceCheckoutOrder")

  @@index([organizationId, status])
  @@index([type, createdAt])
  @@map("checkout_orders")
}

model Payment {
  id                String   @id @default(uuid())
  checkoutOrderId   String   @map("checkout_order_id")
  organizationId    String   @map("organization_id")
  userId            String?  @map("user_id")
  type              String
  provider          String   @default("paypal")
  providerOrderId   String?  @map("provider_order_id")
  providerCaptureId String?  @map("provider_capture_id")
  status            String   @default("pending")
  currency          String   @default("USD")
  actualAmountCents Int      @default(0) @map("actual_amount_cents")
  markupPercent     Decimal  @default(30) @map("markup_percent")
  markupAmountCents Int      @default(0) @map("markup_amount_cents")
  totalAmountCents  Int      @default(0) @map("total_amount_cents")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  checkoutOrder CheckoutOrder    @relation(fields: [checkoutOrderId], references: [id], onDelete: Cascade)
  lineItems     PaymentLineItem[]

  @@index([organizationId, status])
  @@index([checkoutOrderId])
  @@map("payments")
}

model PaymentLineItem {
  id                String   @id @default(uuid())
  paymentId         String   @map("payment_id")
  type              String
  description       String
  actualAmountCents Int      @default(0) @map("actual_amount_cents")
  markupAmountCents Int      @default(0) @map("markup_amount_cents")
  totalAmountCents  Int      @default(0) @map("total_amount_cents")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_line_items")
}

model Deployment {
  id                String    @id @default(uuid())
  organizationId    String    @map("organization_id")
  projectId         String    @map("project_id")
  environment       String
  status            String    @default("queued")
  source            String
  provider          String?
  providerServiceId String?   @map("provider_service_id")
  providerDeployId  String?   @map("provider_deploy_id")
  providerStatus    String?   @map("provider_status")
  commitSha         String?   @map("commit_sha")
  commitMessage     String?   @map("commit_message")
  branch            String?
  triggeredByUserId String?   @map("triggered_by_user_id")
  artifactId        String?   @map("artifact_id")
  startedAt         DateTime? @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  durationMs        Int?      @map("duration_ms")
  errorCode         String?   @map("error_code")
  errorMessage      String?   @map("error_message")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  aliases         DeploymentAlias[]
  artifacts       Artifact[]
  logs            DeploymentLog[]
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredByUser User?        @relation("DeploymentTrigger", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([provider, providerDeployId])
  @@index([projectId, createdAt])
  @@index([triggeredByUserId])
  @@map("deployments")
}

model DeploymentLog {
  id             String   @id @default(uuid())
  deploymentId   String   @map("deployment_id")
  organizationId String   @map("organization_id")
  sequence       Int
  level          String
  message        String
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  deployment   Deployment   @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([deploymentId, sequence])
  @@index([organizationId, createdAt])
  @@map("deployment_logs")
}

model DeploymentAlias {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  projectId      String   @map("project_id")
  deploymentId   String   @map("deployment_id")
  domainId       String?  @map("domain_id")
  hostname       String
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at")

  deployment   Deployment   @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  domain       Domain?      @relation(fields: [domainId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([hostname])
  @@index([deploymentId])
  @@index([domainId])
  @@index([organizationId])
  @@index([projectId, isPrimary])
  @@map("deployment_aliases")
}

model Artifact {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  projectId      String    @map("project_id")
  deploymentId   String?   @map("deployment_id")
  bucket         String
  objectKey      String    @map("object_key")
  sizeBytes      Int       @default(0) @map("size_bytes")
  checksum       String?
  status         String    @default("uploading")
  createdAt      DateTime  @default(now()) @map("created_at")

  deployment   Deployment?  @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([deploymentId])
  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@map("artifacts")
}

model Asset {
  id               String    @id @default(uuid())
  organizationId   String    @map("organization_id")
  uploadedByUserId String?   @map("uploaded_by_user_id")
  bucket           String
  objectKey        String    @map("object_key")
  publicUrl        String?   @map("public_url")
  mimeType         String    @map("mime_type")
  sizeBytes        Int       @default(0) @map("size_bytes")
  checksum         String?
  visibility       String    @default("private")
  metadata         Json      @default("{}")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User?        @relation("AssetUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, visibility])
  @@index([uploadedByUserId])
  @@map("assets")
}

model ActivityLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  actorUserId    String?  @map("actor_user_id")
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  action         String
  message        String
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  actor        User?        @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([organizationId, createdAt])
  @@map("activity_logs")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  actorUserId    String?  @map("actor_user_id")
  action         String
  resourceType   String   @map("resource_type")
  resourceId     String?  @map("resource_id")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  actor        User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([organizationId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

model WebhookEvent {
  id              String    @id @default(uuid())
  organizationId  String?   @map("organization_id")
  provider        String
  eventType       String    @map("event_type")
  externalEventId String    @map("external_event_id")
  payload         Json      @default("{}")
  status          String    @default("received")
  processedAt     DateTime? @map("processed_at")
  errorMessage    String?   @map("error_message")
  createdAt       DateTime  @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([provider, externalEventId])
  @@index([organizationId])
  @@index([provider, status])
  @@map("webhook_events")
}

model OutgoingWebhookEndpoint {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  createdByUserId String?   @map("created_by_user_id")
  url             String
  events          Json      @default("[]")
  secret          String?
  isActive        Boolean   @default(true) @map("is_active")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  deliveries   OutgoingWebhookDelivery[]
  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@map("outgoing_webhook_endpoints")
}

model OutgoingWebhookDelivery {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  endpointId     String    @map("endpoint_id")
  endpointUrl    String    @map("endpoint_url")
  eventType      String    @map("event_type")
  payload        Json      @default("{}")
  status         String    @default("pending")
  statusCode     Int?      @map("status_code")
  responseBody   String?   @map("response_body")
  errorMessage   String?   @map("error_message")
  attemptCount   Int       @default(0) @map("attempt_count")
  deliveredAt    DateTime? @map("delivered_at")
  nextAttemptAt  DateTime? @map("next_attempt_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  endpoint     OutgoingWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([organizationId, status])
  @@index([nextAttemptAt])
  @@map("outgoing_webhook_deliveries")
}

model Notification {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  userId         String    @map("user_id")
  type           String
  title          String
  body           String?
  actionUrl      String?   @map("action_url")
  readAt         DateTime? @map("read_at")
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  eventType      String   @map("event_type")
  channel        String
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, eventType, channel])
  @@index([userId, organizationId])
  @@map("notification_preferences")
}

// ─── VPS Hosting ─────────────────────────────────────────────────────────────

model VpsService {
  id                 String    @id @default(uuid())
  organizationId     String    @map("organization_id")
  projectId          String?   @map("project_id")
  createdByUserId    String?   @map("created_by_user_id")
  checkoutOrderId    String?   @map("checkout_order_id")
  provider           String    @default("vultr")
  providerInstanceId String    @map("provider_instance_id")
  label              String
  hostname           String
  region             String
  plan               String
  osId               Int       @map("os_id")
  osName             String?   @map("os_name")
  status             String    @default("pending")
  mainIp             String?   @map("main_ip")
  vcpuCount          Int?      @map("vcpu_count")
  ramMb              Int?      @map("ram_mb")
  diskGb             Int?      @map("disk_gb")
  monthlyCostCents   Int       @map("monthly_cost_cents")
  markupPercent      Int       @default(30) @map("markup_percent")
  markupAmountCents  Int       @map("markup_amount_cents")
  totalPriceCents    Int       @map("total_price_cents")
  currency           String    @default("USD")
  paypalOrderId      String?   @map("paypal_order_id")
  paypalCaptureId    String?   @map("paypal_capture_id")
  paymentStatus      String    @default("pending") @map("payment_status")
  metadata           Json      @default("{}")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization  Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy     User?                @relation("VpsServiceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  project       Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  checkoutOrder CheckoutOrder?       @relation("VpsCheckoutOrder", fields: [checkoutOrderId], references: [id], onDelete: SetNull)
  actionLogs    VpsActionLog[]
  usageRecords  BillingUsageRecord[] @relation("VpsUsageRecords")

  @@index([organizationId])
  @@index([providerInstanceId])
  @@index([paypalOrderId])
  @@index([checkoutOrderId])
  @@index([createdByUserId])
  @@index([projectId])
  @@map("vps_services")
}

model VpsActionLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  vpsServiceId   String   @map("vps_service_id")
  actorUserId    String?  @map("actor_user_id")
  action         String
  status         String   @default("pending")
  request        Json     @default("{}")
  response       Json     @default("{}")
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")

  vpsService   VpsService   @relation(fields: [vpsServiceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([vpsServiceId])
  @@index([organizationId, createdAt])
  @@map("vps_action_logs")
}

// ─── Web Hosting Services (Render-powered) ────────────────────────────────────

model WebHostingService {
  id                 String    @id @default(uuid())
  organizationId     String    @map("organization_id")
  projectId          String?   @map("project_id")
  createdByUserId    String?   @map("created_by_user_id")
  checkoutOrderId    String?   @map("checkout_order_id")
  provider           String    @default("render")
  providerServiceId  String?   @map("provider_service_id")
  name               String
  slug               String
  serviceType        String    @default("web_service") @map("service_type")
  status             String    @default("pending")
  region             String?
  plan               String?
  url                String?
  customDomain       String?   @map("custom_domain")
  monthlyCostCents   Int       @default(0) @map("monthly_cost_cents")
  markupPercent      Int       @default(30) @map("markup_percent")
  markupAmountCents  Int       @default(0) @map("markup_amount_cents")
  totalPriceCents    Int       @default(0) @map("total_price_cents")
  currency           String    @default("USD")
  billingModel       String    @default("monthly") @map("billing_model")
  paymentStatus      String    @default("pending") @map("payment_status")
  metadata           Json      @default("{}")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization  Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy     User?                @relation("WebHostingServiceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  project       Project?             @relation("WebHostingProject", fields: [projectId], references: [id], onDelete: SetNull)
  checkoutOrder CheckoutOrder?       @relation("WebHostingCheckoutOrder", fields: [checkoutOrderId], references: [id], onDelete: SetNull)
  usageRecords  BillingUsageRecord[] @relation("WebHostingUsageRecords")

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([projectId])
  @@index([providerServiceId])
  @@index([checkoutOrderId])
  @@map("web_hosting_services")
}

// ─── Business Services (domains, email, SSL, etc.) ────────────────────────────

model BusinessService {
  id                  String    @id @default(uuid())
  organizationId      String    @map("organization_id")
  createdByUserId     String?   @map("created_by_user_id")
  checkoutOrderId     String?   @map("checkout_order_id")
  type                String
  provider            String
  providerServiceId   String?   @map("provider_service_id")
  name                String
  status              String    @default("active")
  billingCycle        String    @default("annual") @map("billing_cycle")
  billingAmountCents  Int       @default(0) @map("billing_amount_cents")
  markupPercent       Int       @default(30) @map("markup_percent")
  markupAmountCents   Int       @default(0) @map("markup_amount_cents")
  totalPriceCents     Int       @default(0) @map("total_price_cents")
  currency            String    @default("USD")
  paymentStatus       String    @default("pending") @map("payment_status")
  renewsAt            DateTime? @map("renews_at")
  expiresAt           DateTime? @map("expires_at")
  autoRenew           Boolean   @default(true) @map("auto_renew")
  metadata            Json      @default("{}")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("BusinessServiceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  checkoutOrder CheckoutOrder? @relation("BusinessServiceCheckoutOrder", fields: [checkoutOrderId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([type, status])
  @@index([checkoutOrderId])
  @@map("business_services")
}

// ─── Pricing ──────────────────────────────────────────────────────────────────

model PricingRule {
  id        String   @id @default(uuid())
  scope     String
  key       String
  value     Decimal
  currency  String   @default("USD")
  metadata  Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([scope, key])
  @@index([scope, isActive])
  @@map("pricing_rules")
}
