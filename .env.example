# ── Single server (API + frontend on ONE port) ───────────────────────────────
# npm run dev  → http://localhost:3001  (Express + Vite HMR middleware)
# npm start    → http://localhost:3001  (Express + built dist/) after npm run build
#
# Leave VITE_API_BASE_URL empty so the browser uses same-origin /api/*
VITE_APP_MODE=demo
VITE_API_BASE_URL=



# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED in production. Used to sign JWT access tokens. Generate a long random
# value, e.g. `openssl rand -base64 48`.
JWT_SECRET=
# Access token lifetime (any value jsonwebtoken accepts, e.g. 15m, 1h).
ACCESS_TOKEN_TTL=15m
# Refresh token lifetime in days.
REFRESH_TOKEN_TTL_DAYS=30
# bcrypt cost factor for password hashing.
BCRYPT_ROUNDS=10
# Allow the x-user-id / local-user fallback when no JWT is present.
# Only honoured outside production. Set to "false" to require a token even in dev.
AUTH_DEV_FALLBACK=true

# ── Feature flags (paid MVP launch surface) ──────────────────────────────────
# Live for launch:
FEATURE_SITE_BUILDER=true
FEATURE_ZIP_HOSTING=true
FEATURE_GITHUB_HOSTING=true
FEATURE_HOSTING_DASHBOARD=true
FEATURE_BILLING=true
# Behind Coming Soon until launch-ready:
# Domains: see “Domain names” section below (FEATURE_DOMAINS + VITE_FEATURE_DOMAINS).
FEATURE_VPS=true
VITE_FEATURE_VPS=true
FEATURE_AI_BUILDER=true
FEATURE_TEMPLATE_MARKETPLACE=false
FEATURE_ANALYTICS=false
FEATURE_SETTINGS=false

# Server-side only. Do not expose these with a VITE_ prefix.
RENDER_API_KEY=
RENDER_API_DISABLED=false
# Platform/control-plane service id. Customer repo deploys must create or select separate Render services.
RENDER_SERVICE_ID=
# Required for customer repo service creation.
RENDER_OWNER_ID=
RENDER_DEPLOY_HOOK_URL=
# Render API base URL (default: https://api.render.com/v1)
RENDER_API_BASE_URL=https://api.render.com/v1
# Internal Render provider-cost estimates (for admin margin reporting ONLY —
# never charged to the customer, who always pays the flat K200 per deploy).
RENDER_STANDARD_COST_CENTS=0
RENDER_STATIC_COST_CENTS=0
RENDER_COST_CURRENCY=USD

# ── Deploy-first K200 billing ────────────────────────────────────────────────
# Flat fee per ZIP/GitHub deploy, in PGK toea (default 20000 = K200).
DEPLOYMENT_BILLING_AMOUNT_CENTS=20000
# Hours the customer has to pay before the cleanup job suspends the service.
DEPLOYMENT_BILLING_GRACE_HOURS=12
# PayPal/card cannot settle PGK, so we display K200 but charge this processor
# currency/amount (roughly K200 ≈ US$60). Adjust to your real FX rate.
DEPLOYMENT_BILLING_PROCESSOR_CURRENCY=USD
DEPLOYMENT_BILLING_PROCESSOR_AMOUNT=60.00

# ── ZIP deploy → GitHub → Render pipeline ────────────────────────────────────
# The GitHub repo that stores extracted ZIP uploads so Render can build from them.
# Must be a full HTTPS GitHub URL: https://github.com/your-org/generated-sites
# Glondia production value: https://github.com/pistion/glondia-generated-sites
RENDER_GENERATED_SITES_REPO_URL=
# Optional: subdirectory within the generated-sites repo for each upload
RENDER_GENERATED_SITES_ROOT_DIR=uploaded-sites
# Template library — master templates live in this main repo under /templates/.
# glondia-generated-sites is only for deployed customer copies (RENDER_GENERATED_SITES_REPO_URL).
TEMPLATE_LIBRARY_REPO_URL=https://github.com/pistion/Glondiasites
TEMPLATE_LIBRARY_ROOT=templates
TEMPLATE_LIBRARY_BRANCH=main
RENDER_GENERATED_TEMPLATE_SITES_ROOT_DIR=generated-template-sites
# Fine-grained GitHub PAT with Contents read+write on RENDER_GENERATED_SITES_REPO_URL.
# Create at: GitHub → Settings → Developer settings → Fine-grained personal access tokens
GITHUB_GENERATED_SITES_TOKEN=
# Fallback GitHub PAT used for git clone when user OAuth token is unavailable.
# Also used as publisher token if GITHUB_GENERATED_SITES_TOKEN is not set.
GITHUB_TOKEN=

# ── GitHub OAuth App (used for user sign-in and repo listing) ─────────────────
# Public URL of the frontend app (used for post-OAuth redirects)
FRONTEND_URL=https://yourdomain.com
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Full callback URL registered in the GitHub OAuth App settings
# Must match exactly: https://yourdomain.com/api/v1/auth/github/callback
GITHUB_REDIRECT_URI=
# Shared secret for validating GitHub webhook payloads
GITHUB_WEBHOOK_SECRET=
# Default branch used when GITHUB_DEFAULT_BRANCH is not set per deploy
GITHUB_DEFAULT_BRANCH=main

# ── Google OAuth App (user sign-in) ──────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match exactly what is registered in Google Cloud Console
# e.g. https://yourdomain.com/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=

# ── GitHub App: client import → controlled repo → Render ──────────────────────
# The GitHub-link deploy path imports the client repo using GitHub App
# installation tokens, copies the source into a Glondiasites-controlled repo,
# and Render deploys ONLY from that controlled repo (never the client repo).
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# PEM private key for the GitHub App (\n-escaped or multiline). Used to mint
# installation tokens. Falls back to GITHUB_GENERATED_SITES_TOKEN/GITHUB_TOKEN
# only if those happen to hold an RSA private key.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# Installation id of the Glondiasites App on the platform org (write/create repos).
GITHUB_GLONDIASITES_INSTALLATION_ID=
# Owner (org or user) under which controlled repos are created.
GITHUB_GLONDIASITES_OWNER=pistion
# Prefix and visibility for controlled repos (Mode A: new repo per deployment).
GITHUB_CONTROLLED_REPO_PREFIX=glondia-site
GITHUB_CONTROLLED_REPO_PRIVATE=true

# ── ZIP upload limits ─────────────────────────────────────────────────────────
# Maximum ZIP file size in bytes (default: 100 MB)
MAX_ZIP_BYTES=104857600
# Maximum number of deployable files extracted from a ZIP (default: 5000)
MAX_DEPLOYABLE_FILES=5000
# Maximum size of a single file entry inside the ZIP in bytes (default: 25 MB)
MAX_ENTRY_BYTES=26214400
# Alias used by the ZIP upload route (falls back to MAX_ZIP_BYTES)
ZIP_UPLOAD_MAX_BYTES=104857600
ZIP_UPLOAD_MAX_FILES=5000
ZIP_UPLOAD_MAX_ENTRY_BYTES=26214400

DATA_DIR=.glondia-data
# Temp directory for git clones and build runs (falls back to OS temp dir)
BUILD_TEMP_DIR=
ENCRYPTION_KEY=
CORS_ORIGINS=
JSON_BODY_LIMIT=1mb
PROVIDER_API_ENABLED=true
PROVIDER_API_TOKEN=
PROVIDER_RATE_WINDOW_MS=60000
PROVIDER_RATE_LIMIT=20
GITHUB_REPO_ALLOWLIST=
OPENAI_API_KEY=
OPENAI_MODEL=

# ── Domain names (Spaceship registrar + PayPal checkout) ─────────────────────
# Domains are ON by default in the main customer dashboard (My domains, Buy, DNS).
# Set either flag to false to hide the feature. Live search/purchase still needs
# Spaceship + PayPal credentials below; without them the UI shows a safe
# “not configured” state instead of fake availability.
#
# Provider secrets MUST stay server-side only.
# Never use a VITE_ prefix for SPACESHIP_* or PAYPAL_CLIENT_SECRET values.
FEATURE_DOMAINS=true
VITE_FEATURE_DOMAINS=true
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=
SPACESHIP_API_BASE_URL=https://spaceship.dev/api/v1
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_SANDBOX=true
PLATFORM_MARKUP_PERCENT=30
PLATFORM_PAYPAL_EMAIL=
DOMAIN_REGISTRAR_COST_ACCOUNT=
HOSTING_COST_ACCOUNT=

# ── Business Email (dashboard) + GlondiaMail (webmail) ───────────────────────
# Dashboard Email = mailbox setup, DNS, admin requests (sidebar → Email).
# GlondiaMail = separate webmail at /glondiamail and /mail (read/send).
# Do not mix: configuration stays in the dashboard; reading mail is GlondiaMail.
#
# Provider / IMAP / SMTP secrets MUST stay server-side only.
# Never prefix secrets with VITE_.
FEATURE_EMAIL=true
VITE_FEATURE_EMAIL=true
FEATURE_GLONDIA_MAIL=true
VITE_FEATURE_GLONDIA_MAIL=true

EMAIL_PROVIDER=
EMAIL_WEBMAIL_URL=/mailboxes
EMAIL_MX_HOST=
EMAIL_SPF_RECORD=
EMAIL_DKIM_SELECTOR=
EMAIL_DKIM_RECORD=
EMAIL_DMARC_RECORD=

GLONDIA_MAIL_IMAP_HOST=
GLONDIA_MAIL_IMAP_PORT=993
GLONDIA_MAIL_SMTP_HOST=
GLONDIA_MAIL_SMTP_PORT=465

